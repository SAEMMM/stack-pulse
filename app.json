{
  "expo": {
    "name": "StackPulse",
    "slug": "stack-pulse",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#f4efe6"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "extra": {
      "stackPulse": {
        "requiresHostedApi": true
      }
    },
    "ios": {
      "infoPlist": {
        "NSUserNotificationUsageDescription": "StackPulse uses notifications to alert you to important developer issues."
      },
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#f4efe6"
      }
    },
    "web": {
      "bundler": "metro"
    }
  }
}
